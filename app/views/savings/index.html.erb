<div style="max-width: 1000px; margin: 0 auto;">

    <div style="text-align: center; margin-top: 0.5rem; color: #bb00ff; font-size: 1.2rem; font-weight: bold;">
      今月の我慢貯金額
    </div>

    <div style="text-align: center; margin-bottom: 0;">
        <div style="font-family: 'Courier New', monospace; font-size: 6rem; color: #FFD700; font-weight: bold; margin-bottom: 1rem;">
         ¥ <%= number_with_delimiter(@monthly_total) %>
        </div>

      <%= image_tag "saving_pig.png", alt: "豚の貯金箱", style: "width: 1000px; height: auto; display: block; margin: 0 auto;" %>
    </div>

    <div style="margin-bottom: 2rem; text-align: right; padding-right: 1.5rem">
     <%= link_to '追加', new_saving_path, 
        style: 'background-color: #FFD700; color: #000; padding: 0.5rem 1rem; 
                border-radius: 4px; text-decoration: none; font-weight: bold; 
                display: inline-block;' %>
    </div>

    <% @saving.each do |saving| %>
     <div style="background-color: #1a1a1a; border: 2px solid #333; 
                  border-radius: 8px; padding: 1.5rem; margin-bottom: 1rem;
                  display: flex; justify-content: space-between; align-items: center; gap: 2rem;">
        
         <div style="font-family: 'Courier New', monospace; font-size: 2rem; 
                    color: #FFD700; font-weight: bold; min-width: 150px;">
          ¥<%= number_with_delimiter(saving.amount) %>
         </div>

         <div style="flex: 1; font-size: 1.2rem; font-weight: bold;">
            <%= saving.title %>
         </div>

         <div style="color: #888; font-size: 0.9rem; min-width: 100px; text-align: right;">
            <%= saving.saved_at.strftime('%Y/%m/%d') %>
         </div>

          <%= link_to '詳細', saving_path(saving), 
              style: 'color: #FFD700; text-decoration: none; 
                      border: 1px solid #FFD700; padding: 0.5rem 1rem; 
                      border-radius: 4px; display: inline-block; white-space:  nowrap;' %>
      </div>
    <% end %>
</div>