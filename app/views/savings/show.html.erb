<div style="max-width: 600px; margin: 0 auto; padding: 2rem;">
 <h1 style="text-align: center; color: #bb00ff; margin-bottom: 2rem;">貯金記録詳細</h1>

 <div style="margin-bottom: 1.5rem;">
  <div style="display: block; margin-bottom: 0.5rem; color: #FFD700;">
    我慢したもの
  </div>

  <div style="padding: 0.5rem; border: 1px solid #333; border-radius: 4px; background-color: #1a1a1a;">
    <%= @saving.title %>
  </div>
 </div>

 <div style="margin-bottom: 1.5rem;">
  <div style="display: block; margin-bottom: 0.5rem; color: #FFD700;">
    金額
  </div>

  <div style="padding: 0.5rem; border: 1px solid #333; border-radius: 4px; background-color: #1a1a1a;">
    <%= @saving.amount %>
  </div>
 </div>

 <div style="margin-bottom: 1.5rem;">
  <div style="display: block; margin-bottom: 0.5rem; color: #FFD700;">
    日付
  </div>

  <div style="padding: 0.5rem; border: 1px solid #333; border-radius: 4px; background-color: #1a1a1a;">
    <%= @saving.created_at %>
  </div>
 </div>

 <div style="display: flex;">
  <%= link_to '編集', edit_saving_path(@saving), style: 'background-color: #FFD700; color: #000; padding: 0.5rem 1rem; border: none; border-radius: 4px; font-size: 1rem; margin-top: 1rem;' %>
  <%= button_to '削除', saving_path(@saving), method: :delete, data: { turbo_confirm: '本当に削除しますか？' }, style:'background-color: #000; color: #FFD700; padding: 0.5rem 1rem; border: none; border-radius: 4px; font-size: 1rem; margin-top: 1rem; margin-left: 1rem; cursor: pointer; border: 1px solid #FFD700;' %>
 </div>

 <div style="text-align: center; margin-top: 1rem;">
  <%= link_to '戻る', savings_path, style: "color: #bb00ff;" %>
 </div>
</div>